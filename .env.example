# Local app runtime
APP_ENV=development
DATABASE_URL=.data/aine-bmad-todo.sqlite
HEALTHCHECK_PATH=/api/health/ready
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Docker Compose defaults
COMPOSE_PROJECT_NAME=aine-bmad-todo
COMPOSE_PROFILES=dev
COMPOSE_RUN_DB_MIGRATIONS=true
COMPOSE_HEALTHCHECK_HOST=127.0.0.1
COMPOSE_HEALTHCHECK_PATH=/api/health/ready

COMPOSE_APP_ENV=development
COMPOSE_APP_NODE_ENV=development
COMPOSE_APP_HOST=0.0.0.0
COMPOSE_APP_PORT=3000
COMPOSE_APP_DATABASE_URL=/data/aine-bmad-todo.sqlite
COMPOSE_APP_PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

COMPOSE_TEST_ENV=test
COMPOSE_TEST_NODE_ENV=test
COMPOSE_TEST_HOST=0.0.0.0
COMPOSE_TEST_PORT=3002
COMPOSE_TEST_DATABASE_URL=/data/aine-bmad-todo.test.sqlite
COMPOSE_TEST_PLAYWRIGHT_BASE_URL=http://127.0.0.1:3002
